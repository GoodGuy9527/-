#include "SavingsAccount.h"
#include "CheckingAccount.h"

int main() {

    // ==========================
    // 多型(Polymorphism)
    // 父類別指標指向子類別物件
    // ==========================

    Account* acc1 =
        new SavingsAccount(
            "S001",      // 帳號
            "Kevin",     // 戶名
            1000,        // 初始餘額
            0.05);       // 利率

    Account* acc2 =
        new CheckingAccount(
            "C001",      // 帳號
            "Alex",      // 戶名
            500,         // 初始餘額
            200);        // 透支額度

    // 存款200
    acc1->deposit(200);

    // 提款300
    acc1->withdraw(300);

    // 提款600
    // 500餘額 + 200透支額度
    // 所以允許提款
    acc2->withdraw(600);

    // 顯示 SavingsAccount 資訊
    acc1->displayInfo();

    cout << "----------------" << endl;

    // 顯示 CheckingAccount 資訊
    acc2->displayInfo();

    // 釋放動態記憶體
    delete acc1;
    delete acc2;

    return 0;
}
